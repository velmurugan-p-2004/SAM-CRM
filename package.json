{
  "name": "bill-podu",
  "version": "1.0.1",
  "type": "module",
  "description": "Professional Billing Software - Bill போடு",
  "main": "electron.cjs",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "electron .",
    "clean": "node -e \"const fs = require('fs'); ['dist', 'release'].forEach(d => fs.rmSync(d, {recursive: true, force: true}))\"",
    "build": "tsc && vite build",
    "build:electron": "electron-builder",
    "build:win": "npm run clean && npm run build && electron-builder --win",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "dist": "npm run build && npx serve dist",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "seed": "ts-node src/database/seed.ts"
  },
  "build": {
    "appId": "com.billpodu.app",
    "productName": "Bill போடு",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron.cjs",
      "preload.cjs",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "npmRebuild": false,
    "buildDependenciesFromSource": false
  },
  "keywords": [
    "billing",
    "inventory",
    "pos",
    "electron"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "baseline-browser-mapping": "^2.9.4",
    "concurrently": "^9.2.1",
    "electron": "^38.1.0",
    "electron-builder": "^26.0.12",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.1.3",
    "jest-environment-jsdom": "^30.1.2",
    "png-to-ico": "^3.0.1",
    "serve": "^14.2.5",
    "ts-jest": "^29.4.1",
    "wait-on": "^8.0.5"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@types/electron": "^1.4.38",
    "@types/node": "^24.3.3",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.21",
    "cors": "^2.8.6",
    "electron-vite": "^4.0.0",
    "express": "^5.2.1",
    "jsbarcode": "^3.12.1",
    "lucide-react": "^0.544.0",
    "mysql2": "^3.22.6",
    "postcss": "^8.5.6",
    "qrcode": "^1.5.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "xlsx": "^0.18.5"
  }
}
